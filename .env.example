# ── Next.js (Vercel) ─────────────────────────────────────────
# Copy to .env.local for local dev. Set as Vercel env vars in production.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Cron (Render) ─────────────────────────────────────────────
# Set as Render Environment Variables — NEVER commit these.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Provider: 'football-data' (default) or 'api-football'
PROVIDER=football-data

# football-data.org free tier key (https://www.football-data.org/client/register)
FOOTBALL_DATA_API_KEY=your-football-data-key-here

# API-Football via RapidAPI (only needed if PROVIDER=api-football)
API_FOOTBALL_KEY=your-rapidapi-key-here
